---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = "Find the right cafe in Toronto for working, dates, or just enjoying a coffee.", image = "https://cafesintoronto.com/og-image.png" } = Astro.props;
const canonical = new URL(Astro.url.pathname, "https://cafesintoronto.com").href;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Cafes In Toronto" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <slot name="head" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-012EHZ2GEH"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-012EHZ2GEH');
    </script>
  </head>
  <body class="min-h-screen bg-cream flex flex-col">
    <div class="flex-1">
      <slot />
    </div>
    <footer class="border-t border-gray-200 mt-12">
      <div class="max-w-2xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-400">
        <span>© {new Date().getFullYear()} Cafes In Toronto</span>
        <div class="flex items-center gap-4">
          <div class="relative group">
            <button class="text-caramel hover:underline font-medium">Neighbourhoods ▾</button>
            <div class="absolute bottom-full right-0 mb-2 hidden group-hover:block bg-white border border-gray-200 rounded-xl shadow-lg py-2 w-48 z-10">
              <a href="/chinatown" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Chinatown</a>
              <a href="/distillery" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Distillery</a>
              <a href="/downtown-toronto" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Downtown Toronto</a>
              <a href="/kensington-market" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Kensington Market</a>
              <a href="/king-west" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">King West</a>
              <a href="/liberty-village" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Liberty Village</a>
              <a href="/ossington" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Ossington</a>
              <a href="/queen-west" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Queen West</a>
              <a href="/the-annex" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">The Annex</a>
              <a href="/yorkville" class="block px-4 py-1.5 text-sm text-gray-600 hover:text-espresso hover:bg-gray-50">Yorkville</a>
            </div>
          </div>
          <a href="/blog" class="text-caramel hover:underline font-medium">Blog</a>
          <a href="/submit" class="text-caramel hover:underline font-medium">+ Submit a cafe</a>
        </div>
      </div>
    </footer>
  </body>
</html>
