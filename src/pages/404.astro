---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Cafes In Toronto" description="The page you're looking for doesn't exist. Browse independent coffee shops in Toronto.">
  <main class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-6xl mb-4">☕</p>
    <h1 class="text-3xl font-bold text-espresso mb-3">Page not found</h1>
    <p class="text-gray-500 mb-8">That page doesn't exist. Try browsing cafes by neighbourhood.</p>
    <a href="/" class="inline-block px-6 py-2.5 rounded-full bg-caramel text-white text-sm font-medium hover:opacity-90 transition-opacity">
      Back to all cafes
    </a>
  </main>
</Layout>
