---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog — Cafes In Toronto"
  description="Tips, guides, and lists to help you find the right cafe in Toronto for every occasion."
>
  <main class="max-w-2xl mx-auto px-4 py-10">
    <header class="mb-8">
      <a href="/" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-espresso mb-6 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All cafes
      </a>
      <h1 class="text-3xl font-bold text-espresso mb-1">Blog</h1>
      <p class="text-gray-500">Guides and lists to help you find the right cafe in Toronto.</p>
    </header>

    <div class="space-y-4">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group flex gap-5 bg-white rounded-2xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-200 overflow-hidden p-4"
        >
          <div class="flex flex-col justify-center min-w-0">
            <p class="text-xs text-gray-400 mb-1.5">
              {post.data.pubDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="font-semibold text-lg text-espresso leading-snug mb-2 group-hover:text-caramel transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{post.data.description}</p>
            <span class="mt-3 text-xs font-medium text-caramel">Read more →</span>
          </div>
          {post.data.coverImage && (
            <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-xl overflow-hidden bg-gray-100 flex-shrink-0">
              <img
                src={post.data.coverImage}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          )}
        </a>
      ))}
    </div>
  </main>
</Layout>
