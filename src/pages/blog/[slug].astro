---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — Cafes In Toronto`}
  description={post.data.description}
  image={post.data.coverImage ? `https://cafesintoronto.com${post.data.coverImage}` : undefined}
>
  <main class="max-w-2xl mx-auto px-4 py-10">

    <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-espresso mb-6 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      All posts
    </a>

    {post.data.coverImage && (
      <div class="w-full h-56 sm:h-72 rounded-2xl overflow-hidden mb-8 bg-gray-100">
        <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover" />
      </div>
    )}

    <header class="mb-8">
      <p class="text-xs text-gray-400 mb-2">
        {post.data.pubDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <h1 class="text-3xl font-bold text-espresso leading-tight">{post.data.title}</h1>
    </header>

    <div class="prose prose-gray max-w-none
      prose-headings:text-espresso prose-headings:font-semibold
      prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-3
      prose-p:text-gray-600 prose-p:leading-relaxed prose-p:mb-4
      prose-a:text-caramel prose-a:no-underline hover:prose-a:underline
      prose-strong:text-espresso
      prose-hr:border-gray-200 prose-hr:my-8">
      <Content />
    </div>

  </main>
</Layout>
